# Copy this file to .env and fill in your real values
# cp .env.example .env

# Notion Internal Integration Token
# Get it at: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (primary AI provider)
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API Key (fallback – used if OpenAI fails or times out after 30 s)
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database IDs
TASKS_DATA_SOURCE=your_tasks_data_source_id_here
TASKS_DATABASE_ID=your_tasks_database_id_here
MEETINGS_DATABASE_ID=your_meetings_database_id_here
PROJECTS_DATABASE_ID=your_projects_database_id_here
